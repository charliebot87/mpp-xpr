{
  "name": "mpp-xpr",
  "version": "0.2.0",
  "description": "XPR Network payment method for the Machine Payments Protocol (MPP) — zero gas fees, sub-second finality",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --loader ts-node/esm src/test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mpp",
    "xpr",
    "proton",
    "payments",
    "machine-payments",
    "http-402",
    "web3",
    "crypto",
    "blockchain"
  ],
  "author": "charliebot87",
  "license": "MIT",
  "dependencies": {
    "@proton/js": "^28.1.2",
    "mppx": "^0.5.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
